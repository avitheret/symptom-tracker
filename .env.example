# ── Supabase (optional — enables cross-device cloud auth & sync) ──────────────
#
# Without these variables the app runs in local-only mode:
# accounts and data are stored in this browser's localStorage only.
#
# To enable cloud auth:
# 1. Create a free project at https://supabase.com
# 2. Go to Project Settings → API
# 3. Copy the "Project URL" and "anon / public" key below
# 4. Restart the dev server (Vite picks up .env on startup)
#
# IMPORTANT: never commit a .env file that contains real keys.
#            This file (.env.example) is safe to commit.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
